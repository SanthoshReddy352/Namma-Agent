{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "installer-ui",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "installer/webui"
    },
    {
      "name": "app-ui",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "namma_agent/webui"
    },
    {
      "name": "app-server",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "namma_agent", "--server"],
      "port": 8000,
      "autoPort": true
    }
  ]
}
